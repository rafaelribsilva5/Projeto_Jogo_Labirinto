<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="Projeto_Jogo_Labirinto.PageAgente"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             BackgroundImageSource="fundo_mainpage_escuro2.png">

    <Grid>
        <VerticalStackLayout x:Name="VideoView"
                             Opacity="1"
                             HorizontalOptions="Fill"
                             VerticalOptions="Fill">
            <toolkit:MediaElement x:Name="video1"
                                 Source="embed://video1.mp4"
                                 ShouldAutoPlay="True"
                                 ShouldShowPlaybackControls="False"
                                 ShouldKeepScreenOn="True"
                                 Aspect="AspectFill"
                                 HorizontalOptions="Fill"
                                 VerticalOptions="Fill"
                                 MediaEnded="Video1_MediaEnded"
                                 MediaFailed="Video1_MediaFailed" />
        </VerticalStackLayout>

        
        
        
        
        
        <Grid x:Name="LabirintoView"
                             Opacity="0"
                             IsVisible="False"
                             HorizontalOptions="Fill"
                             VerticalOptions="Fill">
            <Grid ColumnDefinitions="*,*,*"
                  ColumnSpacing="30">
                <ImageButton x:Name ="btn_esquerda"
                    Source="seta_esquerda.png"
                             HorizontalOptions="Center"
                             Grid.Column="0"
                             WidthRequest="120"
                             VerticalOptions="Center"
                             Clicked="BtnEsquerda_Clicked" 
                             BackgroundColor="Transparent"/>
                <ImageButton x:Name ="btn_direita"
                    Source="seta_direita.png"
             HorizontalOptions="Center"
             Grid.Column="2"
             WidthRequest="120"
             VerticalOptions="Center"
             Clicked="BtnDireita_Clicked" 
             BackgroundColor="Transparent"/>
                <ImageButton x:Name ="btn_cima"
     Source="seta_cima.png"
 Grid.Column="1"
HorizontalOptions="Center"
HeightRequest="120"
VerticalOptions="Start"
Margin ="0, 30, 0, 0" 
Clicked="BtnCima_Clicked" 
BackgroundColor="Transparent"/>
                <ImageButton x:Name ="btn_baixo"
                    Source="seta_baixo.png"
                                 HorizontalOptions="Center"
                                 Grid.Column="1"
                                 VerticalOptions="End"
                                 HeightRequest="120"
                                 Clicked="BtnBaixo_Clicked"
                                 Margin ="0, 0, 0, 30" 
                                 BackgroundColor="Transparent"/>
            </Grid>
        </Grid>




        <Grid x:Name="Mensagem"
              Opacity="0"
              IsVisible="False">
            <Button x:Name="lbl_Mensagem"
                    IsEnabled="False"
           TextColor="White"
           FontSize="12"
           HorizontalOptions="Center"
           VerticalOptions="Center"
           WidthRequest="400"
           BackgroundColor="Transparent"
           Text="Infelizmente não dá para passar paredes!"
           CornerRadius="16"
           BorderWidth="2"
           Padding="16"
           BorderColor="#8AF3FE"/>
        </Grid>





        <Grid x:Name="Contagem"
      IsVisible="False">
            <Label x:Name="lbl_Contagem"
   TextColor="White"
   FontSize="70"
   FontFamily="Archive"
   HorizontalOptions="Center"
   VerticalOptions="Center"
   BackgroundColor="Transparent"
   Text="Começa em "/>
        </Grid>

        <Grid x:Name="morse_errado"
      BackgroundColor="#99000000"
    IsVisible="False">

            <Grid ColumnDefinitions="*,5*, *"
          RowDefinitions="*,5*, *"/>
            <Border
BackgroundColor="#B3000105"
Grid.Column="1"
Grid.Row="1"
Stroke="#8AF3FE"
StrokeThickness="2"
Padding="20"
HorizontalOptions="Center"
VerticalOptions="Center">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="15">

                    <Label Text="OH NÃO!"
   FontSize="20"
   FontAttributes="Bold"
   TextColor="#8AF3FE"
   FontFamily="Archive"
   HorizontalTextAlignment="Center"/>
                    <Label
    Text="O código de morse inserido está incorreto. Muita ATENÇÃO, Vamos recomeçar!"
    FontSize="16"
    Grid.Column="0"
    TextColor="White"
    Padding="20"
    HorizontalTextAlignment="Center"
    VerticalOptions="Center"
    HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>
        </Grid>

        <Grid x:Name="botao"
              BackgroundColor="Transparent">

            <Button x:Name="btn_Avancar"
                    Text="Avançar"
                    FontFamily="Archive"
                    FontSize="16"
                    FontAttributes="None"
                    TextColor="White"
                    CornerRadius="14"
                    BackgroundColor="Transparent"
                    BorderWidth="2"
                    Margin="0,0,20,20"
                    BorderColor="#8AF3FE"
                    HorizontalOptions="End"
                    VerticalOptions="End"
                    Clicked="btn_Avancar_Clicked"/>
        </Grid>

        <Grid x:Name="sem_net"
      BackgroundColor="#99000000"
    IsVisible="False">

            <Grid ColumnDefinitions="*,5*, *"
          RowDefinitions="*,5*, *"/>
            <Border
BackgroundColor="#B3000105"
Grid.Column="1"
Grid.Row="1"
Stroke="#8AF3FE"
StrokeThickness="2"
Padding="20"
HorizontalOptions="Center"
VerticalOptions="Center">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="15">

                    <Label Text="LIGAÇÃO PERDIDA!"
   FontSize="20"
   FontAttributes="Bold"
   TextColor="#8AF3FE"
   FontFamily="Archive"
   HorizontalTextAlignment="Center"/>
                    <Label
    Text="Verifica a tua conexão à internet!"
    FontSize="16"
    Grid.Column="0"
    TextColor="White"
    Padding="20"
    HorizontalTextAlignment="Center"
    VerticalOptions="Center"
    HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>
        </Grid>

        <Grid x:Name="parceiro_sem_net"
      BackgroundColor="#99000000"
    IsVisible="False">

            <Grid ColumnDefinitions="*,5*, *"
          RowDefinitions="*,5*, *"/>
            <Border
BackgroundColor="#B3000105"
Grid.Column="1"
Grid.Row="1"
Stroke="#8AF3FE"
StrokeThickness="2"
Padding="20"
HorizontalOptions="Center"
VerticalOptions="Center">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="15">

                    <Label Text="LIGAÇÃO DO GUIA PERDIDA!"
   FontSize="20"
   FontAttributes="Bold"
   TextColor="#8AF3FE"
   FontFamily="Archive"
   HorizontalTextAlignment="Center"/>
                    <Label
    Text="Serás redirecionado para a página inicial!"
    FontSize="16"
    Grid.Column="0"
    TextColor="White"
    Padding="20"
    HorizontalTextAlignment="Center"
    VerticalOptions="Center"
    HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
