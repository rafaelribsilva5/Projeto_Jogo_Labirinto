<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="Projeto_Jogo_Labirinto.PageGuia"
             BackgroundImageSource="labirinto.png"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False">

    <Grid>
        <Grid x:Name="VideoView"
                             HorizontalOptions="Fill"
                             VerticalOptions="Fill">
            <toolkit:MediaElement x:Name="video1"
                                 Source="embed://video1.mp4"
                                 ShouldAutoPlay="True"
                                 ShouldShowPlaybackControls="False"
                                 ShouldKeepScreenOn="True"
                                 Aspect="AspectFill"
                                 HorizontalOptions="Fill"
                                 VerticalOptions="Fill"
                                 MediaEnded="Video1_MediaEnded"/>
        </Grid>




        <Grid x:Name="LabirintoView"
                             IsVisible="False"
                             HorizontalOptions="Fill"
                             VerticalOptions="Fill">
            <Grid x:Name="MapaGrid"
              RowSpacing="0"
              HorizontalOptions="Fill"
              VerticalOptions="Fill"
              ColumnSpacing="0">
            </Grid>
        </Grid>



        <Grid x:Name="ControlosInvertidos"
      BackgroundColor="Transparent"
      IsVisible="False">

            <Grid 
        HorizontalOptions="Center"
        VerticalOptions="Center"
        WidthRequest="300"/>

            <Border
    BackgroundColor="#80000000"
    Stroke="#8AF3FE"
    StrokeThickness="2"
    StrokeShape="RoundRectangle 25"
    Padding="20">
                <VerticalStackLayout Spacing="15">

                    <Label Text="🔴 CONTROLOS INVERTIDOS!"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalTextAlignment="Center"/>

                    <Label Text="↑ agora é ↓
↓ agora é ↑
← agora é →
→ agora é ←"
                           FontSize="16"
                           TextColor="White"
                           HorizontalTextAlignment="Center"/>

                </VerticalStackLayout>
            </Border>


            <Button Text="OK"
                Margin="0,15,0,0"
                BackgroundColor="Transparent"
                TextColor="White"
                CornerRadius="16"
                BorderColor="#8AF3FE"
                BorderWidth="2"
                Clicked="btn_fechar"/>
        </Grid>




        <Grid x:Name="ControlosCorretos"
      BackgroundColor="Transparent"
      IsVisible="False">

            <Grid
        HorizontalOptions="Center"
        VerticalOptions="Center"
        WidthRequest="300"/>

            <Border
    BackgroundColor="Transparent"
    Stroke="#8AF3FE"
    StrokeThickness="2"
    StrokeShape="RoundRectangle 25"
    Padding="20">
                <VerticalStackLayout Spacing="15">

                    <Label Text="🟢 CONTROLOS CORRIGIDOS!"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalTextAlignment="Center"/>

                    <Label Text="A interferência desapareceu.
Os teus comandos respondem corretamente."
                           FontSize="16"
                           TextColor="White"
                           HorizontalTextAlignment="Center"/>

                </VerticalStackLayout>
            </Border>


            <Button Text="OK"
                Margin="0,15,0,0"
                BackgroundColor="Transparent"
                TextColor="White"
                CornerRadius="16"
                BorderColor="#8AF3FE"
                BorderWidth="2"
                Clicked="btn_fechar2"/>
        </Grid>


        <Grid x:Name="Abanar_necessario"
          BackgroundColor="Transparent"
        IsVisible="False">

            <Grid ColumnDefinitions="*,5*, *"
              RowDefinitions="*,5*, *"/>
            <Border
    BackgroundColor="#B3000105"
    Grid.Column="1"
    Grid.Row="1"
    Stroke="#8AF3FE"
    StrokeThickness="2"
    Padding="20"
    HorizontalOptions="Center"
    VerticalOptions="Center">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="15">

                    <Label Text="NOVAMENTE MAIS INTERFERÊNCIA!"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="#8AF3FE"
                           FontFamily="Archive"
                           HorizontalTextAlignment="Center"/>

                    <Grid ColumnDefinitions="2*, *"
                          HorizontalOptions="Fill">
                        <Label Text="A comunicação está instável entre o guia e o agente. Ambos precisam de abanar o telemóvel para fazer uma nova calibragem."
       FontSize="16"
       Grid.Column="0"
       TextColor="White"
       Padding="20"
       HorizontalTextAlignment="Center"
       VerticalOptions="Center"
       HorizontalOptions="Center"/>
                        <Image Source="telemovel_vibrar.png"
       HeightRequest="160"
       Grid.Column="1"
       Margin="10, 0, 0, 0"
       HorizontalOptions="Center" 
       VerticalOptions="Center"/>

                    </Grid>
                    <Label Text="ESTA MENSAGEM DESAPARECERÁ ASSIM QUE A CALIBRAGEM ESTIVER CONCLUÍDA!"
       HorizontalTextAlignment="Start"
       FontFamily="Archive"
       TextColor="#8AF3FE"
       FontSize="12"
       VerticalTextAlignment="Start"
       Margin="8,20,0,0"
       HorizontalOptions="Center"
       VerticalOptions="Start"/>
                    

                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
