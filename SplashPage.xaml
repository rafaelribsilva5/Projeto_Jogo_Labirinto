<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Projeto_Jogo_Labirinto.SplashPage"
             Title="SplashPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundImageSource="splash_image.png">
    <Grid>
        <Grid
        x:Name="SplashGrid"
        BackgroundColor="Black"
        Opacity="1">
            <Image Source="logo_completoo.png"
               Aspect="AspectFit"
               HorizontalOptions="Center"
               VerticalOptions="Center"
               HeightRequest="300"/>
        </Grid>


        <Grid
x:Name="Desenvolvido"
BackgroundColor="Transparent"
Opacity="1"
IsVisible="false">
            <Label Text="Rafael Silva • 2026"
    HorizontalOptions="Center"
    VerticalOptions="End"
    Margin="0,0,0,20"
    TextColor="White"
    FontSize="Medium"
   FontFamily="Archive"/>
        </Grid>
    </Grid>
</ContentPage>