<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="Projeto_Jogo_Labirinto.PageFim"
             Title="PageFim"
             NavigationPage.HasNavigationBar="False"
Shell.NavBarIsVisible="False"
BackgroundColor="Black">
    <Grid>
        <VerticalStackLayout x:Name="VideoView"
                         Opacity="1"
                         HorizontalOptions="Fill"
                         VerticalOptions="Fill">
            <toolkit:MediaElement x:Name="video2"
                             Source="embed://video2.mp4"
                             ShouldAutoPlay="True"
                             ShouldShowPlaybackControls="False"
                             ShouldKeepScreenOn="True"
                             Aspect="AspectFill"
                             HorizontalOptions="Fill"
                             VerticalOptions="Fill"
                             MediaEnded="Video2_MediaEnded"
                             MediaFailed="Video2_MediaFailed" />
        </VerticalStackLayout>


        <Grid>
            <VerticalStackLayout HorizontalOptions="Center"
                                 VerticalOptions="Center">
                <HorizontalStackLayout>
                    <Label x:Name="lbl_texto"
                   Text="TEMPO DE EXECUÇÃO: "
                   HorizontalTextAlignment="Center"
FontFamily="Archive"
TextColor="#8AF3FE"
FontSize="40"
VerticalTextAlignment="Start"
HorizontalOptions="Center"
VerticalOptions="Center"/>
                    <Label x:Name="lbl_Tempo_execucao"
                           Text=""
                   HorizontalTextAlignment="Center"
FontFamily="Archive"
TextColor="White"
FontSize="40"
FontAttributes="Bold"
VerticalTextAlignment="Start"
HorizontalOptions="Center"
VerticalOptions="Center"/>

                </HorizontalStackLayout>
                <Button x:Name="btn_Pagina_inicial"
Text="Página Inicial"
FontFamily="Archive"
FontSize="16"
FontAttributes="None"
TextColor="White"
CornerRadius="14"
BackgroundColor="Transparent"
BorderWidth="2"
Margin="0,10,2,0"
BorderColor="#8AF3FE"
HorizontalOptions="Center"
Clicked="btn_Pagina_inicial_Clicked"/>
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>